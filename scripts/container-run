#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
runtime_dockerfile="${repo_root}/Dockerfile.runtime"
runtime_dir="/go/src/github.com/rancher/rancher"
git_dir=""
git_common_dir=""
allowed_env_vars=(
    REPO
    TAG
    CI
    GOGET_MODULE
    GOGET_VERSION
    RELEASE_ACTION
    RELEASE_TYPE
    POSTRELEASE_RANCHER_VERSION
    POSTRELEASE_RANCHER_STABLE
    DEBUG
    SOME_K8S_VERSION
    V2PROV_TEST_DIST
    V2PROV_TEST_RUN_REGEX
    V2PROV_DISTRO_DATA_DIR
    V2PROV_PROVISIONING_DATA_DIR
    V2PROV_SYSTEM_AGENT_DATA_DIR
    K3S_PINNED_VERSION
    RKE2_PINNED_VERSION
    ARCH
    TEST_DIST
    CHART_VERSION
    CHART_REPO
    CHART_DEFAULT_BRANCH
    REGISTRY
    IMAGE
    IMAGE_AGENT
    CATTLE_AGENT_IMAGE
    CATTLE_CHART_DEFAULT_URL
    CATTLE_FEATURES
    GIT_TAG
    GIT_COMMIT
    GIT_BRANCH
    KUBEBUILDER_ASSETS
    OCI_CHART_DIRS
    OCI_CHART_REPOSITORY
    ENABLE_APPCO_ARTIFACTS
    HTTP_PROXY
    HTTPS_PROXY
    NO_PROXY
    http_proxy
    https_proxy
    no_proxy
    DRONE_BUILD_NUMBER
    DRONE_TAG
    DRONE_COMMIT
    DRONE_BRANCH
    DRONE_BUILD_EVENT
)

normalize_arch() {
    case "$1" in
        x86_64)
            echo amd64
            ;;
        aarch64|arm64)
            echo arm64
            ;;
        s390x)
            echo s390x
            ;;
        *)
            echo "$1"
            ;;
    esac
}

hash_file() {
    if command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{print $1}'
    else
        sha256sum "$1" | awk '{print $1}'
    fi
}

canonical_path() {
    local path="$1"

    if [[ "${path}" != /* ]]; then
        path="${repo_root}/${path}"
    fi

    printf '%s\n' "$(cd "$(dirname "${path}")" && pwd -P)/$(basename "${path}")"
}

restore_permissions() {
    local uid gid

    uid="$(id -u)"
    gid="$(id -g)"

    # If already root, nothing to fix.
    if [ "$uid" = "0" ]; then
        return
    fi

    # Attempt chown directly on the host. On Linux the container runs as root so
    # files may be owned by root; we need sudo to reclaim them. On macOS with
    # Rancher Desktop / Docker Desktop the VM's UID mapping means files already
    # appear owned by the host user, so chown succeeds without sudo.
    if chown -R "${uid}:${gid}" "${repo_root}" "${git_dir}" 2>/dev/null; then
        return
    fi

    # Direct chown failed (Linux non-root without sudo). Try with sudo.
    sudo chown -R "${uid}:${gid}" "${repo_root}" "${git_dir}" 2>/dev/null || true
}

runtime_arch="$(normalize_arch "$(uname -m)")"
runtime_hash="$(hash_file "${runtime_dockerfile}" | cut -c1-12)"
runtime_image="rancher-runtime:${runtime_hash}-${runtime_arch}"
git_dir="$(canonical_path "$(git -C "${repo_root}" rev-parse --git-dir)")"
git_common_dir="$(canonical_path "$(git -C "${repo_root}" rev-parse --git-common-dir)")"
env_file="$(mktemp)"

cleanup() {
    rm -f "${env_file}"
    restore_permissions
}

trap cleanup EXIT

mkdir -p "${repo_root}/bin" "${repo_root}/dist" "${repo_root}/build"

for name in "${allowed_env_vars[@]}"; do
    if [ -n "${!name+x}" ]; then
        printf '%s=%s\n' "${name}" "${!name}" >> "${env_file}"
    fi
done

if ! docker image inspect "${runtime_image}" >/dev/null 2>&1; then
    docker buildx build \
        --build-arg "RUNTIME_HOST_ARCH=${runtime_arch}" \
        --file "${runtime_dockerfile}" \
        --load \
        --platform "linux/${runtime_arch}" \
        --tag "${runtime_image}" \
        "${repo_root}"
fi

while [ "$#" -gt 0 ]; do
    case "$1" in
        -q|--no-out)
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

if [ "$#" -eq 0 ]; then
    set -- ci
fi

if [ -f "${repo_root}/scripts/$1" ] && [ "$1" != "container-run" ]; then
    script_target="$1"
    shift
    set -- "./scripts/${script_target}" "$@"
fi

docker_args=(
    run
    --rm
    --env-file "${env_file}"
    --privileged
    --label "CI=${CI:-}"
    --label "DRONE_BUILD_NUMBER=${DRONE_BUILD_NUMBER:-}"
    --volume "${repo_root}:${runtime_dir}"
    --volume "${git_common_dir}:${git_common_dir}"
    --volume "${repo_root}/build:/tmp"
    --volume rancher2-go16-pkg-1:/go/pkg
    --volume rancher2-go16-cache-1:/root/.cache/go-build
    --workdir "${runtime_dir}"
    --env "ARCH=${ARCH:-${runtime_arch}}"
    --env "HOST_ARCH=${runtime_arch}"
    --env "HOME=${runtime_dir}"
    --env "GOCACHE=/root/.cache/go-build"
    --env "DOCKER_HOST=unix:///var/run/docker.sock"
    --env "GOTELEMETRY=off"
)

# Mount the Docker socket. The path /var/run/docker.sock is resolved inside the
# container runtime's VM (e.g. Rancher Desktop, Docker Desktop), not the macOS
# host filesystem, so the mount works even when the path doesn't exist on the host.
docker_args+=(--volume /var/run/docker.sock:/var/run/docker.sock)

docker_args+=("${runtime_image}")

docker "${docker_args[@]}" "$@"
