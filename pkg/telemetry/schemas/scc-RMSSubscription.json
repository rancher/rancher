{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rancher/rancher/pkg/telemetry/scc-payload",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Product Version normalized for SCC - must be semver. https://semver.org/"
    },
    "subscription": {
      "properties": {
        "installuuid": {
          "type": "string",
          "format": "uuid",
          "description": "The UID of the k8s kube-system namespace."
        },
        "clusteruuid": {
          "type": "string",
          "format": "uuid",
          "description": "Rancher's unique cluster identifier - based on InstallUUID setting."
        },
        "product": {
          "type": "string",
          "description": "cpe of the product"
        },
        "version": {
          "type": "string",
          "description": "Rancher's raw build version"
        },
        "arch": {
          "type": "string"
        },
        "git": {
          "type": "string",
          "description": "Rancher's build git SHA"
        },
        "server_url": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "installuuid",
        "clusteruuid",
        "product",
        "version",
        "arch",
        "git",
        "server_url"
      ]
    },
    "feature_flags": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "Feature flags enabled on RMS https://ranchermanager.docs.rancher.com/getting-started/installation-and-upgrade/installation-references/feature-flags"
    },
    "managedSystems": {
      "items": {
        "properties": {
          "arch": {
            "type": "string"
          },
          "cpu": {
            "type": "integer",
            "minimum": 0,
            "description": "https://kubernetes.io/docs/tasks/configure-pod-container/assign-cpu-resource/#cpu-units status.internalNodeStatus.capacity.cpu"
          },
          "memory": {
            "type": "integer",
            "minimum": 0,
            "description": "Capacity of the node(s): status.internalNodeStatus.capacity.memory (converted to MiB)"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "description": "Count of systems with these attributes (deduplication to shrink data size)",
            "default": 1
          },
          "upstream": {
            "type": "boolean",
            "description": "Identifies the cluster hosting RMS itself"
          }
        },
        "additionalProperties": true,
        "type": "object",
        "required": [
          "arch",
          "cpu",
          "memory",
          "count"
        ]
      },
      "type": "array",
      "description": "Active systems under management and their details; to be expanded"
    },
    "managedClusters": {
      "items": {
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 1,
            "description": "De-duplication of identical clusters"
          },
          "nodes": {
            "type": "integer",
            "minimum": 0
          },
          "upstream": {
            "type": "boolean",
            "description": "Identifies the cluster hosting RMS itself",
            "default": false
          }
        },
        "additionalProperties": true,
        "type": "object",
        "required": [
          "count",
          "nodes"
        ]
      },
      "type": "array"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "version",
    "subscription",
    "managedSystems",
    "managedClusters",
    "timestamp"
  ],
  "title": "RMSSubscription"
}
